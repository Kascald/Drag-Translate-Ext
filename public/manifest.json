{
  "manifest_version": 3,
  "name": "Translate_ext",
  "version": "0.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "description": "선택한 텍스트를 DeepL API를 통해 즉시 번역하는 말풍선 확장 프로그램",
  "permissions": ["storage", "tabs"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["assets/content_script.css"],
      "js": ["content_script.js"]
    }
  ],
  "action": {
    "default_title": "Translate_ext 설정",
    "default_icon": "icon.png",
    "default_popup" : "popup.html"
  }
}
